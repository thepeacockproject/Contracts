    "Metadata": {
        "Id": "1b8e4c56-11b3-4112-afa6-824332f86da9",
        "Type": "usercreated",
        "Title": "Gamemeneer en de ICA data",
        "Location": "LOCATION_ANCESTRAL_BULLDOG",
        "PublicId": "128608936382",
        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_bulldog.entity",
        "TileImage": "$($repository fa0b9f07-d667-48d2-99c0-c5ee905fa973).Image",
        "Description": "KAK!\r47, er is iets aan de hand.\r\rNa je acties in Dubai is toch de informatie die Hans Lucht over de ICA had uitgelekt.\r\rMr. Fernsby en Rebecca Carlisle hebben beiden een token waarmee ze bij de info kunnen in de grote databank. Je moet voorkomen dat zij ooit nog bij die info kunnen. Elimineer ze, en neem hun tokens in beslag.\r\rOok moet je hun advocaat, Aron Ford Jr, elimineren. Hij zit nu een kopie van de info te lezen om de ICA voor de rechter te slepen.\rZorg dat dit niet gebeurd 47.\r\rSucces!",
        "GameVersion": "8.2.0.0",
        "IsPublished": true,
