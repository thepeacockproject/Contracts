    "Metadata": {
        "Id": "1ee11a1c-3b2f-475b-bd12-fc52c06c95a7",
        "Type": "usercreated",
        "Title": "The Money-Lovin&apos; McDonald&apos;s Men",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111568825706",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 604c6ea2-b8e4-4855-bcf2-cde9bd4cec3c).Image",
        "Description": "Jude Gonzales, a member of the kitchen staff here at the Global Innovation Race, has a secret that he has hid for many years. About 5 years ago, he was the manager at a local Miami McDonald&apos;s. He and a few other employees had been doing a get-rich-quick scheme. Jude, with his chemistry knowledge invented a drug that made anyone who consumed it tip extra. One of his fellow accomplists suggested they get a job at the racetrack, to earn money a lot faster. Now&apos;s our chance. Kill em.",
