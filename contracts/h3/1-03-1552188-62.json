    "Metadata": {
        "Id": "b058bce1-568e-4540-b0ee-254fba572e9c",
        "Type": "usercreated",
        "Title": "Trouble at the kitchen",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103155218862",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository 8b0a081a-170a-4a62-a35a-8434279e1509).Image",
        "Description": "Alright, 47, this is finally it - Food Fight day is upon us! \rFor this assignment you will travel to your favorite town, Sapienza, to bring some order into the kitchens. Look at the chefs! Smoking in the kitchen? Absolutely no respect for other people&apos;s lungs.\rNext, you can try your trusty poison on one of the guards. Let poor Silvio live for once, please.\rLastly, look at the assistants! Is that proper kitchen attire? I don&apos;t think so! Go and teach them a lesson!\rGood luck and Have Fun! :)",
        "GameVersion": "8.7.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COASTALTOWN"
        ],
        "CreatorUserId": "86af5ac4-bcca-44cd-aa6e-04fbfab3784b",
        "ServerVersion": "8.7.0.40",
        "CreationTimestamp": "2022-05-05T16:27:25.4580732Z",
