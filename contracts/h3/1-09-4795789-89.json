    "Metadata": {
        "Id": "c9020131-2c73-4779-9c62-53b2709da3b9",
        "Type": "usercreated",
        "Title": "That Incredibly Impressive Life Of Yours",
        "Location": "LOCATION_COLORADO",
        "PublicId": "109479578989",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Colorado_2/_scene_bull.entity",
        "TileImage": "$($repository ff7d3a6c-f9e3-4941-9499-802f6bcf6971).Image",
        "Description": "Give it a thought. Just a little. Okay, maybe a lot. You are actually amazing. I cannot recall anyone ever being just such an awesome and successful bald killer clone. And, in case you missed it, your name is a number! It goes to show how not anyone can even compare to your standards. Perhaps you should exercise how incredibly talented you are to the Shadow Client’s militia and just maybe the world.\r\rI mean, it’s not arrogant if you know it’s true, right?",
        "GameVersion": "8.3.0.0",
