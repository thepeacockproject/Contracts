    "Metadata": {
        "Id": "daa3f279-fa0f-4a2d-b871-5213d0856fd6",
        "Type": "usercreated",
        "Title": "Пропажа защиты дельгадо",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111713245991",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 14ef9606-229b-4ee5-9f79-bd8fa7893e1e).Image",
        "Description": "Здравствуй снова 47-й после твоих проделок разгрома синдикатов, посредников и членов картеля Андрея мартинез и семья дельгадо пришла в ярость. Мартинез наняла в майами киллера а дельгадо с франко начали там новую операцию по перевозке белого товара.\rНе подведи агенство 47-й покажи мартинез кто тут настоящий киллер, убей в качестве предупреждения Салмана аль газали.\rУдачной охоты 47-й.",
        "GameVersion": "8.23.0.0",
