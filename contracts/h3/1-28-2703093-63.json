    "Metadata": {
        "Id": "4845cec1-4fff-4907-b660-3df68662f3ae",
        "Type": "usercreated",
        "Title": "Ending the Year with a Bang",
        "Location": "LOCATION_ANCESTRAL_BULLDOG",
        "PublicId": "128270309363",
        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_bulldog.entity",
        "TileImage": "$($repository 9f6b010a-b4cc-4bda-8200-f132aaad03a4).Image",
        "Description": "The Carlisles have all gathered at Thornsbridge Manor for Christmas, but a disaster fell upon the family: the servants forgot to buy Christmas Crackers this year. Mr Fernsby, the butler, was absolutely outraged by this display of un-Britishness and hired us to make sure the Carlisles wouldn&apos;t spend a Christmas without some familiar banging sounds, and to deliver a few &quot;presents&quot; to the bad children along the way.\r\rMake sure none of these see Santa Claus before he has delivered all his gifts, 47.",
        "GameVersion": "8.10.0.0",
        "IsPublished": true,
