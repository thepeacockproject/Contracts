        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_smoothsnake.entity",
        "TileImage": "$($repository 7b02fa28-081e-420a-91ae-45726306573c).Image",
        "Description": "The Garden Show is not a competition but a trap the Carlisles created to eliminate various enemies in one go and show the family is still powerfull\rKen and his photographer have been selling Information/Photos of the Carlisles to the Media.\rEvelyn stole garden ideas from Zachary to win Competitions.\rGulshan has used his family influence to win many businesses over the Carlsliles.\rSebastian uses his Influencer status to promote Manon&apos;s work and to diminuish the Carlisles.\rAll must be eliminated!",
        "GameVersion": "8.7.0.0",
        "IsPublished": true,
        "Entitlements": [
