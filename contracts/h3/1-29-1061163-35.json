    "Metadata": {
        "Id": "96c9501a-a307-454f-ba9d-46e0f746fd8a",
        "Type": "usercreated",
        "Title": "I want in the club! Screw security!",
        "Location": "LOCATION_EDGY_FOX",
        "PublicId": "129106116335",
        "ScenePath": "assembly:/_pro/scenes/missions/edgy/mission_fox/scene_fox_contractcreation.entity",
        "TileImage": "$($repository 5d411a9a-a807-4e1e-aa29-d236a4b0fedb).Image",
        "Description": "Someone wants to get into the club in Berlin. But on top of asking for tickets, they want to put a sticker over your camera lens and frisk you. Our client hates this and wants to carry their guns and drugs in while taking all the pictures they want. They have asked us to elminate the front door security and the security around the reception desk. I&apos;d advise doing it in a way where nobody can suspect a murder took place. Good luck 47.",
        "GameVersion": "8.23.0.0",
