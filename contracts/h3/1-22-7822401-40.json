    "Metadata": {
        "Id": "078e588c-7991-4b94-ac43-3d916263719f",
        "Type": "usercreated",
        "Title": "A Matter of Family",
        "Location": "LOCATION_NORTHAMERICA",
        "PublicId": "122782240140",
        "ScenePath": "assembly:/_pro/scenes/missions/skunk/scene_skunk.entity",
        "TileImage": "$($repository 3880a7bb-7b59-4a0c-87f2-590e87ccb1ce).Image",
        "Description": "A contract has been issued. We got an annonymous tip about a certain Helen West. I think you&apos;ve met her before, 47. It seems she&apos;s poisoning her muffins and study the reaction on her unfortunate victims. Most end up sick, but there have been a few casualties. Her two sons, Jed and Herbert are in on it, helping her sell them around the neighbourhood. Eliminate Helen, Jed and Herbert West as cleanly as possible, avoiding collateral damage as far as possible.",
