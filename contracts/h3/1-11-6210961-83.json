    "Metadata": {
        "Id": "5ccfe34d-f3fb-41b0-b309-a70dd4d644bc",
        "Type": "usercreated",
        "Title": "The Miami Hustle",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111621096183",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 39cb4cc3-e27e-4dd8-877d-fcbc57836bf4).Image",
        "Description": "Our client this time is something of a high roller. After placing a large bet on the annual Global Innovation Race, he has discovered a ring of corrupt race officials conspiring with a rival gambler to rig the race&apos;s outcome in his favour, in exchange for receiving a cut of the winnings.\rNeedless to say, our client cannot afford to lose this game. He wants all of the men involved in this conspiracy eliminated, to ensure a fair outcome.\rGood hunting, 47.",
