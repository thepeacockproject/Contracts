    "Metadata": {
        "Id": "c7283598-5b69-471e-8e27-ff865e09ad8f",
        "Type": "usercreated",
        "Title": "Engineer and security staff is lazy !?",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111600297162",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository ea638c1b-d4e5-42c9-bf70-e4b2825a846e).Image",
        "Description": "Two engineers are slacking off. One leans on the handrail of the balcony, and the other is installing a mold beside the elevator shaft. The security guards are sleeping in the security room of the underground parking lot!!! \rEmployees like Kronstad should be dismissed!!!\rBut Kronstad did not.\rOur customers have repeatedly asked us to kill the target according to the contract.\rGood hunting 47!",
