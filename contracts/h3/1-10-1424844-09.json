    "Metadata": {
        "Id": "98db2c17-a5b5-4941-966f-3ecbe2ea1b3a",
        "Type": "usercreated",
        "Title": "The Hokkaido Ring",
        "Location": "LOCATION_HOKKAIDO",
        "PublicId": "110142484409",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Hokkaido/_scene_snowcrane.entity",
        "TileImage": "$($repository f19cb43e-7f33-4d27-aa42-ecd7918eb2fe).Image",
        "Description": "47, I have a new mission for you. You&apos;re going back to Hokkaido, so you&apos;ll probably know your way around there.\r\rNow, let&apos;s get to the point. These 5 men have been running a drug smuggling campaign to smuggle drugs into the resort, and an anonymous client is not happy about it. Your task is simple: Eliminate these people and get out of there, do not leave any evidence that could be used against you, because the Director won&apos;t be happy about these people dying.\r\rBest of luck,\rDiana",
        "GameVersion": "8.12.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_HOKKAIDO"
        ],
        "CreatorUserId": "fc62bd6d-2393-4320-b692-1826131d6047",
        "ServerVersion": "8.12.0.55",
        "CreationTimestamp": "2023-05-15T12:30:58.4760275Z",
