    "Metadata": {
        "Id": "89d0e200-cd89-43dc-b470-faa306c01213",
        "Type": "usercreated",
        "Title": "Corruption in Vermont",
        "Location": "LOCATION_NORTHAMERICA",
        "PublicId": "122599197399",
        "ScenePath": "assembly:/_pro/scenes/missions/skunk/scene_skunk.entity",
        "TileImage": "$($repository b8f0bf6c-4826-4de2-a785-2d139967e09c).Image",
        "Description": "Our client suspected suspicious activity among Vermont authorities. This situation did not allow him to do his job calmly. So, you were tasked with killing four of the most important people who were found to be corrupt, giving false testimony, and helping criminals escape punishment through the witness protection program. The murders will cause a stir around this case and probably all those who recently robbed jewelry and swindled on the stock exchange will now be in federal prison.",
