    "Metadata": {
        "Id": "45e5f32e-901f-4ccc-839b-b3db4a34f9b9",
        "Type": "usercreated",
        "Title": "That was no accident!",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111044681180",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository b45fb802-de01-4770-a730-ba39cd116f6f).Image",
        "Description": "These five mechanics used to work on the Gibblo race team. The team was dissolved when their star driver, Zuba Gibblo, died on the track in mysterious circumstances. It was deemed an accident. Our client, Zuba Gibblo Sr., has done his research and it seemed that five of the team&apos;s mechanics conspired to sabotage Gibblo&apos;s car to cause him to lose control mid-race. The motive was revenge for being denied their yearly bonus.\rNow, you&apos;ll have to serve it back to them, 47. Make it look accidental!",
        "GameVersion": "8.7.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_MIAMI"
        ],
