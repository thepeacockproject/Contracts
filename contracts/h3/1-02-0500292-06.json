    "Metadata": {
        "Id": "d6f67388-e106-48a1-babc-97f1127724cb",
        "Type": "usercreated",
        "Title": "A Big One in Paris",
        "Location": "LOCATION_PARIS",
        "PublicId": "102050029206",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Paris/_scene_paris.entity",
        "TileImage": "$($repository 07803e0c-ef2f-41b9-b875-98d56fe43efc).Image",
        "Description": "Dear Munga,\r\rOver the years, I&apos;ve seen your big one do amazing things. Your big one has shown to be extremely good at making things go boom. So, I thought why not bring your prestigious big one in a palace just as prestigious, and you can give all these fancy Frenchmen a good show that they will never forget. And just from looking at your big one over the years, I can tell your a helicopter kind of guy. Good luck and have fun tossing around the biggest one of them all.\r\rSincerely, Diana Burnwood",
        "GameVersion": "8.8.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_PARIS"
        ],
