    "Metadata": {
        "Id": "e8ca5efb-628d-4955-98e2-2abdd4aa80ea",
        "Type": "usercreated",
        "Title": "Тайное зеркало МКА",
        "Location": "LOCATION_NORTHAMERICA",
        "PublicId": "122995067691",
        "ScenePath": "assembly:/_pro/scenes/missions/skunk/scene_skunk.entity",
        "TileImage": "$($repository 79359280-26f8-4dc3-8dc5-f3ff918fbeaa).Image",
        "Description": "Здравствуй 47-й, наши показатели показали странную активность наших агентов. Они не находятся на работе и ведут странные переговоры между собой, наши специалисты смогли прочитать переписку Агента акулы: Лэнса брауна и со остальными тремя. Твоя задача не допустить их скрытый и замаскированный план по не заданному контракту, покажи что будет если не соблюдать правила МКА.\rУдачной охоты 47-й и не забудь, их вид тебя может обмануть они не гражданские лица !",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_NORTHAMERICA"
        ],
        "CreatorUserId": "c2312201-e29e-49a1-9325-a95c8b0e5cb8",
        "ServerVersion": "8.23.0.86",
