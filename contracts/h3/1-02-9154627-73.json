    "Metadata": {
        "Id": "e2ad5729-dd7c-4c06-9ef6-6b88f4400277",
        "Type": "usercreated",
        "Title": "Please Please Kalmer",
        "Location": "LOCATION_PARIS",
        "PublicId": "102915462773",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Paris/_scene_paris.entity",
        "TileImage": "$($repository 3ec5ac4d-77c0-4840-8c1a-3cec7441158f).Image",
        "Description": "Good evening, 47.\n\nTonight’s performance takes place in Paris. Five targets await: two auction staff, two crew members, and His Highness himself.\n\nThe staff and crew are routine work—three will fall to poison injections, while one auction staff member must be eliminated through close-quarters force using an SMG.\n\nThe true challenge lies with the Prince. He must be wearing his own outfit, and the final strike must come from a letter opener.\n\nThere is, however, a complication. To make the opportunity possible, he must first be rendered unconscious and later revived by a guard. If the body is discovered in the wrong state, Silent Assassin is lost.\n\nWith no room to bring a Kalmer, precision and timing are everything.\n\nPlease, please… stay calm.",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_PARIS"
        ],
