    "Metadata": {
        "Id": "ba6ca06f-3fe5-4f63-9b1e-d87b0ee38975",
        "Type": "usercreated",
        "Title": "THE BUTLER DID IT?",
        "Location": "LOCATION_NORTHSEA",
        "PublicId": "121100608317",
        "ScenePath": "assembly:/_pro/scenes/missions/theark/scene_magpie.entity",
        "TileImage": "$($repository 7da7595f-0309-45ee-9f8e-48abffde613d).Image",
        "Description": "Good evening, 47!\r\rYour targets are Providence Constant, Arthur Edwards and his butler, Constantin. Our client, a shadow organization formed by the UN, wants these two removed from the head of this club of &apos;high and mighty&apos; due to security concerns. The contract stipulates that their deaths must come as accidents (presumably to make a mistake cost both their lives) and that you must not harm anyone else in any way. Once you&apos;re done, pop a flare on the roof and we&apos;ll pick you up!\r\rGood luck!",
        "GameVersion": "8.7.0.0",
        "IsPublished": true,
