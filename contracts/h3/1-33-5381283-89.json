        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_smoothsnake.entity",
        "TileImage": "$($repository 8c348ab8-be23-44dc-b48f-cc6ff7379ef3).Image",
        "Description": "A relationship only functions when you are open and honest. Which is what your targets today HAVEN&apos;T done.\r\rRay Wright, taking thousands from his girlfriends bank account, all while being disguised online as a &quot;Antivirus&quot;.\r\rEdwina Hillam, going on dates with other people right under her girlfriend&apos;s nose.\r\rElaine Sutton, dating a multi-billionare only for their money.\r\rWayne Westley, spending time playing &quot;Slapman 6&quot; instead of spending time with his lover.\r\rAx them, should forgiveness be given?",
        "GameVersion": "8.6.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_ANCESTRAL"
        ],
