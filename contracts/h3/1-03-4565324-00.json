    "Metadata": {
        "Id": "0f5cee32-8e60-4044-ae79-7025ce436572",
        "Type": "usercreated",
        "Title": "Hidden in Plain Sight",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103456532400",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository e085ec9f-3830-45cf-a8af-581be15f0d94).Image",
        "Description": "Agent,\n\nSapienza has become a quiet hub for illicit operations, hidden beneath its refined surface.\n\nYour primary target, Silvio Caruso, is not acting alone.\nHis personal security detail and the guards stationed near the underground facility ensure that all activities remain undisturbed — and unseen.\n\nMuch like a traveling operation concealed in plain sight, everything here depends on routine, trust, and the illusion of normalcy.\n\nInfiltrate the mansion as staff. Blend in, move freely, and dismantle the network from within.\nRemove Caruso and those who protect the operation.\n\nNo alarms. No disruption. Let it all appear… ordinary.\n\nGood luck.",
        "GameVersion": "8.23.0.88",
