    "Metadata": {
        "Id": "6a8d327d-cb4a-46b7-92ce-56374daf736f",
        "Type": "usercreated",
        "Title": "Idiot Removal Service",
        "Location": "LOCATION_COLORADO",
        "PublicId": "109073151406",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Colorado_2/_scene_bull.entity",
        "TileImage": "$($repository 7d79859c-7b10-4978-8387-199526dc6220).Image",
        "Description": "Word has it that after the reopening of a taco stand that had been previously shut down, a few drunk lunatics got mad and severely damaged the taco stand after they didn’t get the right order. The owner can easily fix the stand, but what he needs help cleaning is the people, since they’ve also apparently damaged other properties around the town.\r\rAccording to our intel, they all work for the militia in Colorado, and surveillance confirms they are present there today. All you need to do is just locate and lay waste to the four of them, to ensure the damn nuisances won’t bother anyone one else for the rest of the spring season (or for eternity for that matter). Good luck!\r",
        "GameVersion": "8.11.0.52",
