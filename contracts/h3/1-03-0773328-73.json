    "Metadata": {
        "Id": "629b2695-d507-409d-9379-606420764824",
        "Type": "usercreated",
        "Title": "Idle Authority",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103077332873",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository b68a6555-4ecd-4164-9a48-ad2066d23f23).Image",
        "Description": "Good afternoon, 47.\n\nSapienza’s security detail is showing signs of decay. Authority, when left unchecked, tends to erode from within.\n\nYour targets are five guards assigned to the estate. Three continue to perform their duties as mansion security, maintaining the illusion of order. The remaining two—elite operatives in black—have abandoned their responsibilities, idling away their time at the harbor under the protection of their status.\n\nThey wear the same system, but no longer serve it.\n\nEliminate all targets while they remain in their assigned uniforms. Method is entirely up to you.\n\nLet’s see how you handle imbalance, 47.",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
