    "Metadata": {
        "Id": "e64ccbe8-3080-413d-a18c-5db33a9aebe0",
        "Type": "usercreated",
        "Title": "禁止钓鱼",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103849791837",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository 59c487c1-e830-45df-832d-227887580b08).Image",
        "Description": "蓝色边疆组织在这座小镇的成员，同时也是我们的客户，要求我们务必消灭这五个钓鱼爱好者。他认为钓鱼是一种极其罪恶的、破坏海洋的行为，他希望这样能够让钓鱼这种爱好就此从小镇上消失。我不知道该如何评价，不过还是祝你好运，47。",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COASTALTOWN"
        ],
