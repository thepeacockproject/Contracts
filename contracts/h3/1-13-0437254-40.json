    "Metadata": {
        "Id": "31e6de0a-840b-447f-81d8-51cd0e6d2c50",
        "Type": "usercreated",
        "Title": "The Deal",
        "Location": "LOCATION_MUMBAI",
        "PublicId": "113043725440",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Mumbai/scene_mongoose.entity",
        "TileImage": "$($repository d45c4ba4-7260-436d-941d-3359248bcac2).Image",
        "Description": "Due to the fear of becoming a target of 47, Danwood Rangan has made a deal with the ICA, in which he arranges a meeting between Vanya Shah, the Maelstrom and himself. While the meeting the ICA can kill both targets. Unfortunately somebody hired a group of assasins, trying to prevent Danwood Rangan from making the necessary phone call for the meeting. 47, Your mission is to kill the assasins, before they can get to Danwood Rangan. It&apos;s urgent, so you got no more than 5 minutes. Good luck 47.",
