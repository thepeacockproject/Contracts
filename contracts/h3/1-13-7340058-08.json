    "Metadata": {
        "Id": "8d0a9d72-41e3-4beb-b447-10182b6bbed8",
        "Type": "usercreated",
        "Title": "Mumbai Mungday",
        "Location": "LOCATION_MUMBAI",
        "PublicId": "113734005808",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Mumbai/scene_mongoose.entity",
        "TileImage": "$($repository 80051c02-e026-40fe-970a-7b7aaa62302c).Image",
        "Description": "Greetings, 47.\r\rThis Monday takes us to Mumbai.\r\rOur client has identified five individuals who have, in various ways, become liabilities. Their professions and affiliations differ, but the outcome must be the same.\r\rThe client is not fond of unnecessary violence. No collateral damage. Leave minimal evidence, and avoid disguises, innocents must not be framed.\r\rMumbai is warm this time of year. Some casual, light and inconspicuous outfit should be ideal for this assignment. \r\rGood hunting.",
        "GameVersion": "8.23.0.0",
