    "Metadata": {
        "Id": "c382554e-d732-4672-8979-e8baade1f56b",
        "Type": "usercreated",
        "Title": "The Raven and the Well",
        "Location": "LOCATION_COASTALTOWN_NIGHT",
        "PublicId": "104855568621",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_mamba.entity",
        "TileImage": "$($repository e41a2c8f-269c-464e-9fa4-6628db3f6b60).Image",
        "Description": "There once was a raven who was in need of a drink.\rBut to fill the nearest well he had to really think.\r\r47 pebbles in a pitcher were thirst quenching for the crow.\rSo how many men can go in the well? Does anyone know? \r\rThen in the distance, he could hear a faint voice.\r&quot;Fore!&quot; was the reply - and so 4 was his choice.\r\rSo quench your thirst for violence with these targets 4.\rHow is up to you - as long as they live... Never More.",
