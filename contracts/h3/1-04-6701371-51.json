    "Metadata": {
        "Id": "f4ffd1a0-81f5-402b-9022-071a39ebf8c0",
        "Type": "usercreated",
        "Title": "The Sapienza Conspiracy 2: Dusk",
        "Location": "LOCATION_COASTALTOWN_NIGHT",
        "PublicId": "104670137151",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_mamba.entity",
        "TileImage": "$($repository 4f388b6a-0fe0-4119-a9b3-1792922ce76e).Image",
        "Description": "NOON responds so quickly to our contracts due to their flexible system of cells. Fortunately, their response to the Bosco contract was sloppy, and we have determined that the leader of the Italian cell is Salvatore Bravuomo, who has stationed agents throughout town. \r\rWe believe that Marco Abiatti is trying to contact the cell for unkown reasons. Unfortunately for him, he also knows that Bravuomo is the leader, and so his bodyguard has been paid off to kill him. \r\rWe cannot allow this, 47.",
