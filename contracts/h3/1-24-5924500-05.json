    "Metadata": {
        "Id": "1d38f4c2-7ebd-4300-8a22-75dc29f3ff48",
        "Type": "usercreated",
        "Title": "Home Alone in New York",
        "Location": "LOCATION_GREEDY_RACCOON",
        "PublicId": "124592450005",
        "ScenePath": "assembly:/_pro/scenes/missions/Greedy/mission_raccoon/scene_raccoon_basic.entity",
        "TileImage": "$($repository 4d4ee135-ef81-4b66-8149-ad774fb34970).Image",
        "Description": "Santa Claus is our client this eve. He just got fired from his job, and Christmas is coming soon. The Corporate Rats from the HR Department know no mercy, and they want to replace him with a young and ambitious careerist - he don&#39;t even have a beard! Fortunately, the famous New York Duncan&#39;s Toy Chest is nearby - you can equip yourself with the right toys and outfit of Santa Helper there. Santa Claus can&#39;t be involved into this crime. \r\r\r\rSome body will be Home Alone this Christmas.\r\r\r\rShade\r\r\n\r\n<HCCE>",
        "GameVersion": "8.10.0.49",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_GREEDY"
        ],
