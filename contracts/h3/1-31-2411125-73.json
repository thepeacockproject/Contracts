    "Metadata": {
        "Id": "bb82d03f-e77e-46e3-ab8a-28d87c1b8f1f",
        "Type": "usercreated",
        "Title": "The Invisible Circle",
        "Location": "LOCATION_ELEGANT_LLAMA",
        "PublicId": "131241112573",
        "ScenePath": "assembly:/_pro/scenes/missions/elegant/scene_llama.entity",
        "TileImage": "$($repository 9052b694-0d9a-4679-b024-aa56f9e46cde).Image",
        "Description": "An organization without a face.\r\nA network without a name.\n\nIntelligence has identified six individuals connected through a hidden structure operating in the shadows.\r\nThey are not leaders in the public eye.\n\nBut together, they form the core of something far more dangerous.\n\nTheir influence reaches across governments, corporations, and intelligence agencies.\n\nEvery major incident leaves a trace… one that inevitably leads back to them, before vanishing without a trace.\n\nThey do not exist on paper.\nThey do not answer to anyone.\nYour mission is clear: eliminate all six.\nNo noise. No witnesses. No evidence.\nBreak the circle… and whatever remains will disappear into silence.",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_ELEGANT"
        ],
        "CreatorUserId": "9d3a3a07-0018-4d24-a224-0a5f3bdaf3c8",
