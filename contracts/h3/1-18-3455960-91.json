    "Metadata": {
        "Id": "29c819ba-97fe-4ebd-a386-7c523c7e6b0b",
        "Type": "usercreated",
        "Title": "Опасное прикосновение",
        "Location": "LOCATION_HOKKAIDO_FLU",
        "PublicId": "118345596091",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Hokkaido/_scene_flu.entity",
        "TileImage": "$($repository 6c2d2f6c-61cd-40b0-994b-54ba5f8e7c43).Image",
        "Description": "Добро пожаловать в Хоккайдо 47-й, Твоя цель- Оуэн кейдж и его распорядители, Оуэн специально принял новый эксперимент Гама и ему ввели вирус который разносится по воздушно кабельному пути. Но чтобы его от туда не выпустили Гама собрался бывших работников Псих больницы для сурового и агрессивного содержания подопытного.\rНаш клиент также отметил что Вирус слишком опасен поэтому тебе надо раздобыть защитный костюм.\rУдачи 47-й всё в твоих руках.",
        "GameVersion": "8.23.0.0",
