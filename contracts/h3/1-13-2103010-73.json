    "Metadata": {
        "Id": "fbbbd1be-542c-4d97-b2c8-60451e9af1b8",
        "Type": "usercreated",
        "Title": "Eviction Notices",
        "Location": "LOCATION_MUMBAI",
        "PublicId": "113210301073",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Mumbai/scene_mongoose.entity",
        "TileImage": "$($repository 516ca389-fd0f-4dcc-921a-c7f58a455e3c).Image",
        "Description": "A number of complaints have been raised concerning some troublesome tenants occupying the chawls. An anonymous tenant has hired you to issue them &quot;eviction notices&quot;, and has supplied you with a master key for easy access to all apartments. It&apos;s best if the aftermath is left out of sight, and collateral is a giveaway. Good luck.\r\r(This contract was designed to be completed with no starting equipment, besides a lockpick. All recommended kill methods are available within the immediate vicinity.)",
