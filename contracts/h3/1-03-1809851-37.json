    "Metadata": {
        "Id": "8b38970c-a56f-4e95-8796-2876c3d7ef6d",
        "Type": "usercreated",
        "Title": "不受打扰",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103180985137",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository 729aa28f-5856-449a-9e41-3e4fedc5c38f).Image",
        "Description": "这次我们的客户依然是西尔维奥·卡鲁索，大名鼎鼎的生物工程师。他希望我们能够消灭公司派来对他进行监视和随时替换他的德·桑蒂斯，还有德·桑蒂斯雇佣的企图调查他秘密的私家侦探、德·桑蒂斯收买了的两位庄园保安，以及一个总是不时望向他的庄园、令他感到心理上的不适的嬉皮士。他希望我们能够尽可能将暗杀伪装成各种事故，因为他不希望他的工作受到警察和公司的调查的影响，他正是为了不被干涉所以才再次与ICA签订了刺杀契约。上次你的表现堪称完美，ICA相信你同意能够完成这次的契约，祝你好运，47.",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COASTALTOWN"
        ],
