    "Metadata": {
        "Id": "e0cda6a9-344a-4ab0-901b-289ee1978dd7",
        "Type": "usercreated",
        "Title": "From Santa To Tobias",
        "Location": "LOCATION_GOLDEN_GECKO",
        "PublicId": "127166878834",
        "ScenePath": "assembly:/_pro/scenes/missions/golden/mission_gecko/scene_gecko_basic.entity",
        "TileImage": "$($repository 1f6ce142-5929-4e8a-822c-579027244773).Image",
        "Description": "Dear Tobias,\rThank you for your letter. I am proud to learn that you successfully accomplished your duties again this year. I agree to send you a samurai outfit, lotus flowers and an original Providence pin as you requested. However, I have a syndicate of thieves that must be defeated. They have been stealing my warehouses. Dear Tobias, can you do me a favor?\r\r(Submission for the Official Community Featured Contracts : &quot;Winter Contracts&quot;)",
        "GameVersion": "8.10.0.0",
        "IsPublished": true,
        "Entitlements": [
