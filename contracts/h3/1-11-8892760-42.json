    "Metadata": {
        "Id": "324e860f-6ee3-49e9-b46d-f2d7c3eb62dd",
        "Type": "usercreated",
        "Title": "BCR VOL. 75 - Don&apos;t burn my buns",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111889276042",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository e6b8e082-38a1-4107-ae70-9087037d86b9).Image",
        "Description": "Agent 47,\r\rMiami — sunburns, engine noise, and meat crimes beyond forgiveness. Someone turned this place into a circus of grease and regret: burger flippers who hate burgers, hot dog artists who fear dignity, a blue driver “resting” like a corpse with benefits, and a mascot… oh, the mascot… smiling like it already knows  his destiny..\r\rA huge THANK YOU to the whole BCR community, my mods Blauball, ReTwice,Celllie and all supporters.\rLet&apos;s grow together.\r\rCheers,\rBurgers",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
