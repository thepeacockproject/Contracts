    "Metadata": {
        "Id": "f67f3f78-8f90-4680-acf7-978c8850bd6c",
        "Type": "usercreated",
        "Title": "House of Assassins",
        "Location": "LOCATION_MUMBAI",
        "PublicId": "113621612947",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Mumbai/scene_mongoose.entity",
        "TileImage": "$($repository 80051c02-e026-40fe-970a-7b7aaa62302c).Image",
        "Description": "The Mumbai Chawls have been infiltrated by assassins. Rival Assassins. The Kashmirian, Kamal Datta, Vaishnavi Dayal, Aahana Dayal (No Relation), and Rajesh Naidu are all resident assassins of Mumbai. They have agreed to meet in the chawls to  plan the assassination of Dawood Rangan and Vanya Shaw. These people are very important to the ICA, do not let them be eliminated. This is the perfect opportunity to take care of every rival agent. Good luck, 47.",
        "GameVersion": "8.9.0.0",
