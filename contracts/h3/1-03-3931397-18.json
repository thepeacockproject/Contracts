    "Metadata": {
        "Id": "d487184c-cafb-471e-a934-9de84fb6a351",
        "Type": "usercreated",
        "Title": "Jealousy,  Betrayal and Murder",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103393139718",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository 729aa28f-5856-449a-9e41-3e4fedc5c38f).Image",
        "Description": "Good afternoon, 47.\r\rOur client, Orlando Siciliano, has hired us to eliminate his wife, Silvia Masullo, due to an affair she has been having with the town Bohemian, Torres Piombo.\r\rHowever, Mr. Siciliano has contacted the police and asked for protection in exchange for information about the ICA. This cannot be allowed to happen.\r\rFulfill the contract, then send a clear message by eliminating Siciliano and his police contact, Daniel Samper. \r\rFour targets. Two plots. I shall leave you to prepare",
        "GameVersion": "8.1.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COASTALTOWN"
        ],
        "CreatorUserId": "ce17993f-5c92-44b0-b6c9-324e7c3b4701",
