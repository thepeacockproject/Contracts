    "Metadata": {
        "Id": "8d6f168b-bad6-4fef-9f73-5eb96c4fd537",
        "Type": "usercreated",
        "Title": "新人的第二次速通【ICA设施突发事件】",
        "Location": "LOCATION_ICA_FACILITY",
        "PublicId": "101485800418",
        "ScenePath": "assembly:/_pro/scenes/missions/thefacility/_scene_polarbear_005.entity",
        "TileImage": "$($repository 579f2544-1970-4865-afa3-ad4566e5f98d).Image",
        "Description": "【20多年前】Good morning Agent 47.首先我得告诉你一个不幸的消息，索德斯说服了ICA董事会，让你进行复试，这场复试的难度在ICA训练考核中是史无仅有的，这是第一次出现五目标的考核，竟然还有额外要求。不过，我相信你一定能完成，接下来是任务简报：你的目标JASPER，CILAS是克格勃的间谍与头号长官，只有解决他们才能解决客户心头之恨，此外你还要消灭CILAS的三名心腹，就是他们掩护JASPER逃到古巴机场的。我就不打扰你准备了，Good Luck 47",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "CreatorUserId": "6762d85b-7f22-40f1-b1b4-945039f06df0",
