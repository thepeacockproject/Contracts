    "Metadata": {
        "Id": "58da4bd5-877a-4fc2-96b4-d18d04625ad4",
        "Type": "usercreated",
        "Title": "The Polarity Syndicate",
        "Location": "LOCATION_MARRAKECH",
        "PublicId": "106046056357",
        "ScenePath": "assembly:/_pro/scenes/missions/marrakesh/_scene_spider.entity",
        "TileImage": "$($repository 45463b89-0bda-408c-99be-698e1028c24c).Image",
        "Description": "Your five targets are members of the Polarity Syndicate, a group responsible for flooding the market with fake magnets, causing everything from fridge souvenirs to whiteboard notes sliding quietly to the floor. \r\rWhile their crimes may seem trivial, their operation has proven remarkably widespread and  irritating. Direct action would raise too many questions. Instead, their deaths must appear as a string of unfortunate accidents.\r\rAfter all, Agent… It seems their luck just couldn’t stick.",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_MARRAKECH"
        ],
        "CreatorUserId": "f7fd702b-661c-4560-a6bc-767768a0ae1f",
