    "Metadata": {
        "Id": "02def831-853c-4a25-abc1-c7ed5a32b17a",
        "Type": "usercreated",
        "Title": "The Chongqing Connection",
        "Location": "LOCATION_WET_RAT",
        "PublicId": "130752129972",
        "ScenePath": "assembly:/_pro/scenes/missions/wet/scene_rat_basic.entity",
        "TileImage": "$($repository 47424c02-bb0f-4066-af5a-f1cdcdcd08b2).Image",
        "Description": "47,\r\rOne of our contacts in Chongqing has requested that you carry this hit.\r\rThe client would like to eliminate her former friends, all of whom she had a falling out with. This includes Agent Pritchard: our traitor. \r\rShe contacted her old friend Xiaoqing Feng and set up a meeting with her. This was done for the sake of making this particular elimination easier for you. The rest, you will have to find.\r\rThe client requested that Yuan Lin be &quot;sliced like a pig.&quot;\r\r\rDiana Burnwood",
        "GameVersion": "8.4.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_WET"
        ],
