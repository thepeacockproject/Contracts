    "Metadata": {
        "Id": "61173167-960a-416a-8d90-b91c40190a19",
        "Type": "usercreated",
        "Title": "Chawl Chleanout",
        "Location": "LOCATION_MUMBAI",
        "PublicId": "113730760669",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Mumbai/scene_mongoose.entity",
        "TileImage": "$($repository 80051c02-e026-40fe-970a-7b7aaa62302c).Image",
        "Description": "Would it kill these people to give you some peace and quiet?\r\rMight as well go out of your way to earn that peace and quiet. An assassin, a singer, a dancer and two other loud residents of the Chawl will find their graves today. \r\rIt&apos;s unfortunate that it had to come down to this but sometimes you just need to make them quit their noise-making. Maybe after it&apos;s all done, you could go buy some noise muffling headphones or something. \r\rEh. What can ya&apos; do?",
        "GameVersion": "8.8.0.0",
