        "Type": "usercreated",
        "Title": "The Rincewind Intrication",
        "Location": "LOCATION_COLORADO",
        "PublicId": "109723129998",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Colorado_2/_scene_bull.entity",
        "TileImage": "$($repository a900ddd9-7bb9-414d-8715-5ea41684d656).Image",
        "Description": "Good Morning 47,\r\rYour destination is an old Apricot Farm in Colorado, USA. Our Analysts have managed to recover data from a Flashdrive that contains intel on a planned Militia strike in a residential area in Wellington where the Vice President of Dynasty Global, Lance Donovan lives. The file includes a map of the Sewers and describes how two teams will be sent to extract the Target. This plan must be stopped by assasinating all Militia Members associated with it.\r\rI will leave you to prepare.",
        "GameVersion": "8.12.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COLORADO"
        ],
