    "Metadata": {
        "Id": "208f3cca-d3a6-44ea-928c-66ac51ccb5ed",
        "Type": "usercreated",
        "Title": "Miami Vax",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111428359854",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 35b393a7-7b60-48d8-9507-7b1993daa7a9).Image",
        "Description": "This is an odd one, 47. We have been contracted to save lives instead of taking them this time around. The city of Miami requests that these 5 antivaxers be forced to take their &quot;vitamins&quot;. They have also provided us with special rounds compatible with your pistol but you&apos;ll need to aim for the head. The vaccination is hard on the system and they will need some time to rest so make sure every target has a comfy spot to sleep it off. \r\rHappy hunt... er... Happy healing, 47.",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
