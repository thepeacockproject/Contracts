    "Metadata": {
        "Id": "75eebe6f-9ebe-49ae-bb6f-3ca94dc166b5",
        "Type": "usercreated",
        "Title": "April Fools letter from Diana",
        "Location": "LOCATION_ANCESTRAL_SMOOTHSNAKE",
        "PublicId": "133003533062",
        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_smoothsnake.entity",
        "TileImage": "$($repository 3df18163-f19c-4fde-9780-3050436ab053).Image",
        "Description": "It&apos;s come to my attention Lucy Phillips has been experimenting with a love potion on a few lonely people at this Easter garden party. You are going to have to inject her with strychnine of course.\rMy car leaked some kind of fluid yesterday, 47. I collected the fluid in this vial. Inject the love sick Samuel Taylor with it.\rYou&apos;ll find the two harlots Charlie Randal and Rikki Badcock at this party as well. I want to see gore, 47.\r\rLove\rDiana",
        "GameVersion": "8.11.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_ANCESTRAL"
        ],
        "CreatorUserId": "4e4abe9b-1ec5-46a4-86d1-f7965ae743e1",
