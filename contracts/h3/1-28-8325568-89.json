    "Metadata": {
        "Id": "42096af4-c5c8-45af-a3d7-fa5af82e6f14",
        "Type": "usercreated",
        "Title": "Jarl&apos;s Prideful Revenge",
        "Location": "LOCATION_ANCESTRAL_BULLDOG",
        "PublicId": "128832556889",
        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_bulldog.entity",
        "TileImage": "$($repository fa0b9f07-d667-48d2-99c0-c5ee905fa973).Image",
        "Description": "As the ghost of the honorable pirate, Captain Jarl, you must defend and preserve your legacy. You have taken to haunting your mother&apos;s old mansion in the depths of the Dartmoor National Park in England. The mansion was once held in esteem as the home where the Jarl grew up, but it was recently infested with a rich and prissy family of oil tycoons and manipulators. You will not allow your name to be disgraced like this, and you must take revenge. Kill the Butler, Head of Staff, Emma, and Edward.",
        "GameVersion": "8.3.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_ANCESTRAL"
        ],
