    "Metadata": {
        "Id": "bd86a87f-28a6-4c2d-8609-37b3cc97e206",
        "Type": "usercreated",
        "Title": "Wait… That’s Not a Glenn???",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111086212290",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 90cc6741-5c98-45bb-8acc-a9f3baf8c00d).Image",
        "Description": "Good afternoon, 47.\r\rThe sun is shining, the crowd is roaring, and yet behind the scenes, things are falling apart.\r\rOur client, a major event sponsor, is facing a “brand inconsistency.” Names, faces, and expectations don’t align - and with cameras everywhere, optics matter.\r\rGlenn Henson. Kirsten Willard. Elisa Graves. Mariela Volbuena. Eddie Brock.\r\rYou’ve been hired to quietly resolve the issue. \rBlend in, enjoy the spectacle, and complete this… rebranding.\r\rTry not to mislabel anyone.",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_MIAMI"
        ],
        "CreatorUserId": "72574084-3245-47fc-b458-f121870c7ccf",
