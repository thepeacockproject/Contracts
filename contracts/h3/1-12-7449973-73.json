    "Metadata": {
        "Id": "10e18617-e911-48e5-b351-e07a657b8867",
        "Type": "usercreated",
        "Title": "Cold Gold, Warm Trigger",
        "Location": "LOCATION_COLOMBIA",
        "PublicId": "112744997373",
        "ScenePath": "assembly:/_pro/scenes/missions/colombia/scene_hippo.entity",
        "TileImage": "$($repository 928efcc4-9b16-452b-ae8e-17162b8f8830).Image",
        "Description": "Gold.\nThe color of wealth, power… and obsession.\n\nOur client has identified five individuals who have taken their greed too far—each one hiding in plain sight, cloaked in gold, believing themselves untouchable.\n\nLike the man they unknowingly emulate, they worship the metal more than life itself.\n\nYour task is simple:\nenter their gilded world… and turn their fortune into their downfall.\n\nEnsure all five targets are eliminated while surrounded by gold.\nLet their final moments reflect the very thing they value most.\n\nAfter all, 47…\neverything shines brighter just before it fades.\r\n\r\n<HCCE>",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COLOMBIA"
        ],
