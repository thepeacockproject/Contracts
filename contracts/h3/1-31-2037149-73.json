    "Metadata": {
        "Id": "048d2695-1f95-48f5-9210-0e48030be863",
        "Type": "usercreated",
        "Title": "The Invisible Circle",
        "Location": "LOCATION_ELEGANT_LLAMA",
        "PublicId": "131203714973",
        "ScenePath": "assembly:/_pro/scenes/missions/elegant/scene_llama.entity",
        "TileImage": "$($repository 9052b694-0d9a-4679-b024-aa56f9e46cde).Image",
        "Description": "An organization without a face.\r\nA network without a name.\n\nIntelligence has identified six individuals connected through a hidden structure operating in the shadows.\r\nThey are not leaders in the public eye.\n\nBut together, they form the core of something far more dangerous.\n\nTheir influence reaches across governments, corporations, and intelligence agencies.\n\nEvery major incident leaves a trace… one that inevitably leads back to them, before vanishing without a trace.\n\nThey do not exist on paper.\n\nThey do not answer to anyone.\n\nYour mission is clear: eliminate all six.\n\nNo noise. No witnesses. No evidence.\n\nBreak the circle… and whatever remains will disappear into silence.",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_ELEGANT"
        ],
