    "Metadata": {
        "Id": "4a69c309-6c96-4094-adfe-98f6d430b29d",
        "Type": "usercreated",
        "Title": "Bravuomo Protection Squad",
        "Location": "LOCATION_COASTALTOWN_NIGHT",
        "PublicId": "104485118454",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_mamba.entity",
        "TileImage": "$($repository a80bb6dd-5290-4c5f-a8c8-f3568c8425fa).Image",
        "Description": "Good Evening, 47. Marco Abiatti, corrupt politician, is trying to control local lawyer legend Salvatore Bravuomo after he found details that could expose him. The good lawyer is too pure to hire a hit, so his brother did it instead. He doesn&apos;t wish Abiatti to die yet, as he believe&apos;s Salvatore&apos;s dirt will be much more fitting. He wishes you to dispatch of the bodyguard squad in search of Bravuomo on the streets. We don&apos;t know where Salvatore is, so you are on the clock. Good Luck, 47.",
        "GameVersion": "8.7.0.0",
