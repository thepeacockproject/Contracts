    "Metadata": {
        "Id": "f065817c-6706-4b41-bba5-c11fc32dc3ea",
        "Type": "usercreated",
        "Title": "...It Tolls for Thee",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103689082932",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository c823beec-3d73-47b6-87d9-076c384c4662).Image",
        "Description": "I don&apos;t aask for much.\r\rYes, I studied hard for my Phd and I do sometimes wonder if I&apos;m wasting it working for Etherlabs, but Sapienza is an idyllic place and I could be happy here if only I was allowed to see it.\r\rI used to climb the spire of the church and allow the vista and fresh sea air to purge me of my demons and tge dankness of that cave, but Caruso didn&apos;t like it and neither did the local priest and his groundskeepers. They stopped me climbing the stairs countless times.\r\rMake them pay!",
        "GameVersion": "8.23.0.0",
