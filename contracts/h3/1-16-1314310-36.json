    "Metadata": {
        "Id": "f422ed85-7fee-4579-a89a-c8c0db0e382b",
        "Type": "usercreated",
        "Title": "The Shiny Head",
        "Location": "LOCATION_BANGKOK_ZIKA",
        "PublicId": "116131431036",
        "ScenePath": "assembly:/_pro/scenes/missions/Bangkok/scene_zika.entity",
        "TileImage": "$($repository 97fa7a20-7c71-46a4-859e-761aa7397803).Image",
        "Description": "On a cold October night, the Himmapan will become the grounds of an event that&apos;s as old as time, One man with an axe, lots of victims.\r\rThe ghost of Jack Torrance has risen once again, and this time he&apos;s possesed 47&apos;s body! He wants to relive his golden days and has decided to recreate his most thrilling murders. Four victims of the axe, and one brutally shot in the head.\r\rGood night, and good luck 47.",
        "GameVersion": "8.10.0.0",
        "IsPublished": true,
        "Entitlements": [
