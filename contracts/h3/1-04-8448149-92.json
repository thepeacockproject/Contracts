    "Metadata": {
        "Id": "fca1a0af-0ac6-4a28-b476-1a93cb670f78",
        "Type": "usercreated",
        "Title": "Contract Addendum I: The Bitter Fruit",
        "Location": "LOCATION_COASTALTOWN_NIGHT",
        "PublicId": "104844814992",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_mamba.entity",
        "TileImage": "$($repository c823beec-3d73-47b6-87d9-076c384c4662).Image",
        "Description": "Agent.\r\rLetting Abiatti live was clearly a move that benefitted him and Providence more than it did either of us. Father Francesco, Roberto Mulo, Abiatti, and even the once meek Bravuomo have all tripled their material wealth since we terminated our previous contract. \r\rClearly this is a loose end that ties us back to the time when we unwittingly toiled as Providence fingers.  Hopefully this is the last of it. \r\r\rYour payment has already been transferred.",
        "GameVersion": "8.7.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COASTALTOWN"
        ],
        "CreatorUserId": "0d6ff8a1-883b-4b52-b202-83e49e93bc70",
