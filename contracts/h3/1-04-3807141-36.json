    "Metadata": {
        "Id": "c980a98f-84bf-4f0e-a7f1-0143455728e5",
        "Type": "usercreated",
        "Title": "Mafia Author Snitch",
        "Location": "LOCATION_COASTALTOWN_NIGHT",
        "PublicId": "104380714136",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_mamba.entity",
        "TileImage": "$($repository 42e7d00a-b477-4c4f-8b13-8cd4e7403e0d).Image",
        "Description": "Many years ago, Marco Abiatti worked for the Mob as a trusted Capo, however, after his betrayal of the family in working with the FBI as a rat, he was placed under witness protection. Now, he has re-emerged under a fake name and is on a press tour to market his new book “The Don” that is a seemingly fictionalised version of his time in the Mob. He cannot live to finalise its contents being published as it may tarnish the family as we know it. Eliminate him along with his trusted bodyguards.",
        "GameVersion": "8.19.0.0",
