    "Metadata": {
        "Id": "b9da47a4-fb10-4936-ba4b-e1eb16c42597",
        "Type": "usercreated",
        "Title": "To Mock a Killing Bird",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111106412067",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository a27afd9c-4187-4c9c-9785-f82d7e966f28).Image",
        "Description": "A bird is mocked by three men. &quot;His large clumsy feet are good only for tripping!&quot;, one  jeered. &quot;Look at his googly eyes, I bet they have no acuity at all!&quot;, another jested. &quot;Look at those weak arms, they could not snap a twig!&quot;, the last man sneered. &quot;Yes, this pathetic silly bird will never fly&quot; the three men agreed.\r\rLittle did they know that appearances can be deceiving.",
        "GameVersion": "8.10.0.0",
