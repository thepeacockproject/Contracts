    "Metadata": {
        "Id": "1f45e839-ec39-4872-98dc-b93f01a323c0",
        "Type": "usercreated",
        "Title": "Серьезный приговор",
        "Location": "LOCATION_NORTHAMERICA",
        "PublicId": "122402768891",
        "ScenePath": "assembly:/_pro/scenes/missions/skunk/scene_skunk.entity",
        "TileImage": "$($repository 53406e7a-83d4-4dfd-a5f9-839d6f5e3baa).Image",
        "Description": "Здравствуй 47-й после твоих двух дел в санта фортуне мы смогли прочтить тайные переписки и документы Рико дельгадо, оказывается что в Уиттлтоне крике уже как многие года проживают посредники картеля которые готовятся к операции: Дельгадо. Все цели являются не законными мигрантами из Канады, мексики и китая которые выполняют приказы Франко и Дельгадо\rУдачи 47-й цели очень опасные но уязвимы ведь они сделали акцент на заманивание целей в арендованные дома.",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
