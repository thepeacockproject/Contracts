    "Metadata": {
        "Id": "960edbba-42d4-4024-b787-41f9c54597aa",
        "Type": "usercreated",
        "Title": "A Long Way From Home - I",
        "Location": "LOCATION_COLOMBIA",
        "PublicId": "112715303106",
        "ScenePath": "assembly:/_pro/scenes/missions/colombia/scene_hippo.entity",
        "TileImage": "$($repository d7b1d56d-9d8e-41ee-b929-8db7b444c0c6).Image",
        "Description": "47, welcome to Santa Fortuna. Recently, a female Latvian scientist by the name of Eva Vitola has pinged the ICA’s radar many times over the past weeks. Many hits have been performed by Mrs. Vitola across Europe and many alphabet agencies requested us target her in exchange for a large sum of money. We have received intel that tells us she will be traveling to South America in the next few days to eliminate an unknown target. We’ve located her contacts in Colombia. Eliminate them.",
        "GameVersion": "8.9.0.0",
