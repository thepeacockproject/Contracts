    "Metadata": {
        "Id": "b84cc552-81d9-48e5-a71f-496e681f4e22",
        "Type": "usercreated",
        "Title": "The Eggheads",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111738141155",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 6a1d5a96-66d5-424e-9a94-cdada18d326a).Image",
        "Description": "Our client has grown wary of Kranstadt&apos;s rapid advancements in automobiles as of late. Our mission is to eliminate any Kronstadt engineers who know the ins and outs of their cutting edge tech in order to send a message to their higher-ups. All of our targets should be in one place for the event, which gives us the perfect opportunity to act.\r\rBy the way, 47, since you&apos;re in Miami and right in the area, could you pick me up a bite from that place by the docks when you leave?",
