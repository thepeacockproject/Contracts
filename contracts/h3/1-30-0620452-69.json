    "Metadata": {
        "Id": "0a13696f-c089-4552-8e23-ccaf3de4b09d",
        "Type": "usercreated",
        "Title": "Vaguely Vile Vagabonds",
        "Location": "LOCATION_WET_RAT",
        "PublicId": "130062045269",
        "ScenePath": "assembly:/_pro/scenes/missions/wet/scene_rat_basic.entity",
        "TileImage": "$($repository 321920ae-38e6-4323-9e75-c86415f223ab).Image",
        "Description": "The local police department reached out to Agent 47, because they worked with him in the past to apprehend the illegal pasta smugglers. As it turns out, in China, these criminals tend to hide in plain sight by posing as homeless people. Such lack of class really bothers Agent 47, as he helps the homeless in his time off the job. He&apos;s tracking down a tip from the local police, and they allow him to go all sniper assassin on these criminals.",
