    "Metadata": {
        "Id": "654ff214-08bc-4f8d-947d-c72d6c73b5be",
        "Type": "usercreated",
        "Title": "Alle gegen Marie (5 Marie&apos;s gegen dich)",
        "Location": "LOCATION_BANGKOK_ZIKA",
        "PublicId": "116122838641",
        "ScenePath": "assembly:/_pro/scenes/missions/Bangkok/scene_zika.entity",
        "TileImage": "$($repository 7448de96-cfaf-4c5f-8f51-c2cf64da9f72).Image",
        "Description": "Sie haben den Auftrag und die entsprechende Zugriffsfreigabe erhalten. Vergewaltigen (optional: eliminieren) Sie alle Ziele welch sich als Marie identifizieren und das Original (Patient Null) so hart, präzise und rektal wie möglich, da sie eine erhebliche Bedrohung für die Welt, die Menschheit, die Umwelt und potentielle Opfer welche Marie verfallen könnten und in folge dessen depressiv werden hat. Zudem vermeiden Sie auf keinen Fall unnötige Kollateralschäden.\rBesagt die Lucas&apos;sche These.",
        "GameVersion": "8.14.0.0",
        "IsPublished": true,
        "Entitlements": [
            "H1_LEGACY_EXPANSION"
        ],
