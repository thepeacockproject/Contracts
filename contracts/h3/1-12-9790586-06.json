    "Metadata": {
        "Id": "87040064-d52e-40f8-9033-14eb20508fb4",
        "Type": "usercreated",
        "Title": "FPS: Feline Protection Service",
        "Location": "LOCATION_COLOMBIA",
        "PublicId": "112979058606",
        "ScenePath": "assembly:/_pro/scenes/missions/colombia/scene_hippo.entity",
        "TileImage": "$($repository fa140a32-57ca-42c7-bc5c-d2a367e08683).Image",
        "Description": "Good afternoon, 47. We&#39;re headed off to Colombia today, as Catalina Delgado, wife of famous cartel leader Rico Delgado, has been in contact with a few Europeans in the past week.\r\rYou see, Catalina is already in possession of various fur products. However, she has decided she wants to add a few more coats into her collection, specifically those made from the fur of the Carpathian Lynx.\r\rShe recently sent four individuals to eastern Slovakia, one of the many homes of the particular species, in order to make a deal with Slovak hunters, in exchange for the highest quality Colombian cocaine. Ya know, it&#39;s funny that someone with the word cat in their name wants to kill cats.\r\r47, we ask that you eliminate Catalina in a humorous way, by killing her with a part of the thing she&#39;s killing, in the form of the deadly Cat Claw. We also ask that you eliminate the four individuals she sent to Eastern Europe last week, in order to hopefully interrupt their foreign relations.\r\rGood luck.",
        "GameVersion": "8.14.0.60",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COLOMBIA"
        ],
