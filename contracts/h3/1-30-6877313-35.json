    "Metadata": {
        "Id": "5ff2e60d-9565-481c-a602-16fbb25c2562",
        "Type": "usercreated",
        "Title": "DJ&apos;S vs. THE TRAITORS&apos; 4",
        "Location": "LOCATION_WET_RAT",
        "PublicId": "130687731335",
        "ScenePath": "assembly:/_pro/scenes/missions/wet/scene_rat_basic.entity",
        "TileImage": "$($repository 6a3ae9cb-1a19-4748-8450-6d241eb46e6b).Image",
        "Description": "Hey 47. It&apos;s me again. Kenkin Tezuka.\r\rThe bikers of Berlin are just the tip of the Iceberg. There are some people in Chongqing who were very close friends of me and my people. \rBut one day, they wanted to dismantle the entire Club to convert it into a strange laboratory for a man called Hush.\r\rI need you to eliminate them before they take legal measures against us.\r\rI think there&apos;s a good sniper&apos;s nest at the top of one building. It would be lucky if you can find a sniper rifle.\r\rDJ&apos;S FOREVER!",
        "GameVersion": "8.5.0.0",
        "IsPublished": true,
