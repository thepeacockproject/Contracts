    "Metadata": {
        "Id": "4e974f16-0304-4f26-b7c8-d34e245257d3",
        "Type": "usercreated",
        "Title": "Poisoned Silence",
        "Location": "LOCATION_ANCESTRAL_BULLDOG",
        "PublicId": "128404423973",
        "ScenePath": "assembly:/_pro/scenes/missions/Ancestral/scene_bulldog.entity",
        "TileImage": "$($repository 3c125feb-13af-4fd2-9f85-f6c411c0162b).Image",
        "Description": "Good evening, 47.\n\nYour destination is Dartmoor, where a carefully constructed illusion of order is about to collapse. Five individuals have been marked: a photographer capturing more than images, a maid who knows too much, a private investigator digging in the wrong places, the eldest daughter guarding her legacy, and a mansion guard tasked with keeping secrets buried.\n\nEach target moves within routines built on trust — routines you will quietly corrupt. Administer ingested poison to all five targets and let the estate itself turn against them. However, subtlety alone will not suffice. You are also instructed to use a firearm that does not favor silence, fracturing the fragile calm that binds this place together.\n\nConfusion will be your ally. Fear will be your cover.\n\nGood luck, 47.",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_ANCESTRAL"
        ],
