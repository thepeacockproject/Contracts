    "Metadata": {
        "Id": "708a2345-e1c2-4aa7-a1f6-dfd41ee644e3",
        "Type": "usercreated",
        "Title": "Hidden Moles",
        "Location": "LOCATION_OPULENT_STINGRAY",
        "PublicId": "126360813884",
        "ScenePath": "assembly:/_pro/scenes/missions/Opulent/mission_stingray/scene_stingray_basic.entity",
        "TileImage": "$($repository dd4e0a16-7b15-4b32-880d-945adbfe8bb0).Image",
        "Description": "Hello 47,\r\rWe&apos;ve been brought back to Haven Island after leaked security footage of your previous time here. We have found that three moles have been caught leaking information to the other side. The other side asked for more evidence, so the three are disguised with Hilde Sorbetto and Dr. Singh as tourists and Raafida Al-salem as a worker looking for any evidence they can find. It&apos;s a easy but important contract. Take them out 47 or we are done for good. We all trust you.\r\r- Diana",
        "GameVersion": "8.17.0.0",
