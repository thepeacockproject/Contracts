    "Metadata": {
        "Id": "57fa1dcd-3c0e-4482-a334-82504b16bf00",
        "Type": "usercreated",
        "Title": "The Accidental Heist Job",
        "Location": "LOCATION_GREEDY_RACCOON",
        "PublicId": "124758597506",
        "ScenePath": "assembly:/_pro/scenes/missions/Greedy/mission_raccoon/scene_raccoon_basic.entity",
        "TileImage": "$($repository 1ea813c8-038d-473a-aecb-ac9afe0adbdb).Image",
        "Description": "It seems a heist may occur today in NY, 47. All you got to do is eliminate the ringleaders and their inside peeps, accidentally of course. Don&apos;t feel bad either, 47, for everyone entering this bank hears these words:\r\rEnter, stranger, but take heed\rOf what awaits the sin of greed,\rFor those who take, but do not earn, \rMust pay most dearly in their turn.\rSo if you seek beneath our floors\rA treasure that was never yours,\rThief, you have been warned, beware\rOf finding more than treasure there.",
