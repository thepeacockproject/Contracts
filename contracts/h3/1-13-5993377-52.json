    "Metadata": {
        "Id": "bab79e92-5461-4082-8997-99d1ccdc731d",
        "Type": "usercreated",
        "Title": "The Tourist",
        "Location": "LOCATION_MUMBAI",
        "PublicId": "113599337752",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/Mumbai/scene_mongoose.entity",
        "TileImage": "$($repository 90255fb4-5ec7-4191-94bd-1d6c0fa73618).Image",
        "Description": "Dawood Rangan has hired us to eliminate Preeti Shila, aka The Tourist. Preeti has strong ties with the crows in the city, she&apos;s been sending Rangan death threats, and plans to assassinate him. She may look like an innocent tourist, but don&apos;t be fooled, she is pure evil. Her lackeys won&apos;t be hard to find, though one of them is in the Rangan tower guarding the stairs, if Rangan goes that way he&apos;ll trip him. Once you have eliminated all of the assassins, Mr Rangan can breathe a sigh of relief.",
