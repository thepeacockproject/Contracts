    "Metadata": {
        "Id": "4d755b94-caf8-4857-8a8d-06bc6384c7b6",
        "Type": "usercreated",
        "Title": "BCR VOL. 81 - I DONT LIKE WINE",
        "Location": "LOCATION_ELEGANT_LLAMA",
        "PublicId": "131584011089",
        "ScenePath": "assembly:/_pro/scenes/missions/elegant/scene_llama.entity",
        "TileImage": "$($repository daa6a057-d25c-488e-96e4-1a36aed4b994).Image",
        "Description": "Well 47,\r\rMendoza. A vineyard full of people sniffing wine like it’s breathing air, nodding as if oxygen suddenly has “notes of oak.” Only four targets are here — some drinking, some pretending they’re working, all convinced they’re the most refined item on spot.\r\rStart wherever you like. Bring whatever keeps you sane through the theatre. And remember… in a place obsessed with such taste, it’s funny how quickly things can turn (you) sour.\r\rMay they never see you coming.\r\rCheeeeeers,\r\rBurgers",
        "GameVersion": "8.23.0.0",
        "IsPublished": true,
        "Entitlements": [
