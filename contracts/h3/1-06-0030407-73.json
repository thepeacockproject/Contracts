    "Metadata": {
        "Id": "a74dfd4f-db80-4a7b-b103-e81fb1dc2224",
        "Type": "usercreated",
        "Title": "A Measure of Solace",
        "Location": "LOCATION_MARRAKECH",
        "PublicId": "106003040773",
        "ScenePath": "assembly:/_pro/scenes/missions/marrakesh/_scene_spider.entity",
        "TileImage": "$($repository ad482f31-033c-4d89-9db2-3c2ba22f7351).Image",
        "Description": "Agent,\n\nThe unrest you see is no accident.\n\nIt is shaped, directed, and sustained by those who remain hidden within it. Vendors, civilians, and enforcers alike — each playing their part in a system that thrives on controlled disorder.\n\nYou will act within that disorder.\n\nAccidents will happen. Attention will follow. That is expected.\n\nWhat matters is that no suspicion falls on you.\n\nOne target requires a precise method. The rest must be removed in ways that appear incidental… unavoidable.\n\nDo not expect resolution.\n\nAt best, this will offer… a measure of solace.",
        "GameVersion": "8.23.0.88",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_MARRAKECH"
        ],
