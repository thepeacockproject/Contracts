    "Metadata": {
        "Id": "32de17c1-33b8-42ff-b49c-b61521959a53",
        "Type": "usercreated",
        "Title": "Источник вируса",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103594296191",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository 805ba790-e7c3-4c25-9d60-0fe9f5c49fc1).Image",
        "Description": "Здравствуй 47-й, после нашего визита в Хоккайдо мы смогли обнаружить источник вируса который был введен Оуэну Кейджу. Ты направляешься в Сапиенцу и там как раз разрабатывают новую партию Био вируса который будет отправлен на самолете, Твоя задача не допустить крупную поставку Био оружия для тайных лиц правительства. Также как и наш прошлый клиент просит быть осторожным ведь прототип вируса намного опасен чем его завершенная версия вколотому Оуэну.\rУдачной охоты 47-й.",
        "GameVersion": "8.23.0.0",
