    "Metadata": {
        "Id": "08f5563c-a624-4366-b23c-9872350108f1",
        "Type": "usercreated",
        "Title": "Cappin the Cap Gang",
        "Location": "LOCATION_COASTALTOWN",
        "PublicId": "103724863863",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_octopus.entity",
        "TileImage": "$($repository 6e8d9322-3f82-41ca-92db-ede215925a50).Image",
        "Description": "A notorious gang of pickpockets, which members are recognized by the caps they&apos;re wearing, arrived in Sapienza a while ago. They&apos;re posing as fishermen to seize up tourists they intend to steal from. The local mafia doesn&apos;t like criminal activity they can&apos;t control - so they hired us to get rid of the Cap Gang, and send a message to anyone who would encroach on their turf.",
        "GameVersion": "8.10.0.0",
        "IsPublished": true,
        "Entitlements": [
