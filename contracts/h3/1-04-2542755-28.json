    "Metadata": {
        "Id": "d298ec70-c208-4fdf-9c56-f2efb696a655",
        "Type": "usercreated",
        "Title": "The Bravuomo Situation",
        "Location": "LOCATION_COASTALTOWN_NIGHT",
        "PublicId": "104254275528",
        "ScenePath": "assembly:/_PRO/Scenes/Missions/CoastalTown/_scene_mamba.entity",
        "TileImage": "$($repository 4f388b6a-0fe0-4119-a9b3-1792922ce76e).Image",
        "Description": "Good afternoon, 47.\r\rOur client is Marco Abiatti, politician and heartthrob of the Almafi coast.  Abiatti has sanctioned a hit on his formal legal advisor, Salvatore Bravuomo after the latter lost an important case involving the misapropriation of campaign funds.  He suspects Bravuomo is hiding somewhere by the town square.  The client also requests that you dispose of the three guaards stationed around Bravuomo&apos;s office.  Loose ends, and all that.\r\rI will leave you to prepare.",
        "GameVersion": "8.3.0.0",
        "IsPublished": true,
        "Entitlements": [
            "LOCATION_COASTALTOWN"
        ],
