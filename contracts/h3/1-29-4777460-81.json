    "Metadata": {
        "Id": "1df7a1b1-28b7-40bf-9ba1-e91a3bda5954",
        "Type": "usercreated",
        "Title": "O Christmas Tree",
        "Location": "LOCATION_EDGY_FOX",
        "PublicId": "129477746081",
        "ScenePath": "assembly:/_pro/scenes/missions/edgy/mission_fox/scene_fox_contractcreation.entity",
        "TileImage": "$($repository e0aeb574-898d-4f29-b9a4-3d08d89a079c).Image",
        "Description": "With Christmas around the corner, many people are looking for a decorative tree for their home. In Berlin there have been talks about sourcing those trees from the forest near Club Hölle. However, a few people are currently blocking this idea and it is your job to get those troublemakers out of the way. Make sure to have the eliminations look like accidents and wear the Santa suit, if you have it unlocked. Happy Holidays!",
