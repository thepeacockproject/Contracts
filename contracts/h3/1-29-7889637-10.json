    "Metadata": {
        "Id": "5a599edf-8225-41da-a2b1-13923ca9d095",
        "Type": "usercreated",
        "Title": "The Inspector",
        "Location": "LOCATION_EDGY_FOX",
        "PublicId": "129788963710",
        "ScenePath": "assembly:/_pro/scenes/missions/edgy/mission_fox/scene_fox_contractcreation.entity",
        "TileImage": "$($repository 9c4cc4ef-3242-467a-9753-d998ad22a344).Image",
        "Description": "Good Morning, 47. Our client is a german food inspector, who is currently unavailable for this year, so he has asked you to make a thorough investigation in Club Hölle. He has so far determined that the food and drinks there only get replaced once every 2 years, meaning they order in bulk. Although your job is to do an examination, our client&apos;s top concern is the 5 people who he has marked from his previous year for termination. They take more than they need from the bulk order. Good luck.",
        "GameVersion": "8.6.0.0",
        "IsPublished": true,
