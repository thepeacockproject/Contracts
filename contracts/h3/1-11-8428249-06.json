    "Metadata": {
        "Id": "d221ff2c-ec63-4099-a72e-f9df75352f20",
        "Type": "usercreated",
        "Title": "Daily Dose of Hitman - #2",
        "Location": "LOCATION_MIAMI",
        "PublicId": "111842824906",
        "ScenePath": "assembly:/_pro/scenes/missions/miami/scene_flamingo.entity",
        "TileImage": "$($repository 55c9c357-9b04-4506-a13b-98fae0958d61).Image",
        "Description": "In this second installment of Daily Dose of Hitman, you, 47, the best assassin on the ICA&apos;s payroll has come to Miami on vacation. While there, it seems you have left a few accidents waiting to happen lying around. It&apos;s been three days, and they still haven&apos;t slipped up. So, even though it&apos;s dangerous, you are going to speed things up. To make it less obvious, you should dress as a mechanic. May the odds ever be in your favor, and good luck.",
        "GameVersion": "8.7.0.0",
        "IsPublished": true,
        "Entitlements": [
