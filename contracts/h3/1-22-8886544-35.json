    "Metadata": {
        "Id": "c23e54a6-b24c-4c6a-94c6-cba6430ded83",
        "Type": "usercreated",
        "Title": "Toxic war #5",
        "Location": "LOCATION_NORTHAMERICA",
        "PublicId": "122888654435",
        "ScenePath": "assembly:/_pro/scenes/missions/skunk/scene_skunk.entity",
        "TileImage": "$($repository 90505cde-9b68-488f-827b-ff81498264aa).Image",
        "Description": "Good evening agent, today we are heading to Whittleton creek. Where, a campaign for the well known politician &quot;charles blake III&quot; is taking place. We&apos;ve heard from the neighborhood, that he has a few sketchy people in the town, which are helping his campaign. But as per the information we have, he&apos;s not a great leader as per his track record. A contract has been issued to eliminate him and people working for him. Make sure that the kill method is some sort of lethal poison. \rGood Luck\rby AKCSE",
