    "Metadata": {
        "Id": "2c3e7908-6478-4f7b-a041-9e433358a4d4",
        "Type": "usercreated",
        "Title": "Последний маффин",
        "Location": "LOCATION_NORTHAMERICA",
        "PublicId": "122318291391",
        "ScenePath": "assembly:/_pro/scenes/missions/skunk/scene_skunk.entity",
        "TileImage": "$($repository a6aa8b8f-24d3-44b7-ba89-063c251d4881).Image",
        "Description": "здраствуй 47-й, твоя цель это Хелен вест и её помощники.\rХелен- знаток всего уиллтона крика и знаменитость чья история стартовала еще с 70-80х годов, хелен получала и получает статус знаменитости за счет продажы черничных маффинов которые нравится всей улице. Но наше агентсво и клиент так не считают ведь хеллен травит и издевается над людьми. Поэтому тебе нужно как можно быстрее избавиться от неё её же способом: утоплением\rЕщё частный двор охраняется и не грех убить её телохранителей.\rУдачи 47-й",
        "GameVersion": "8.23.0.0",
